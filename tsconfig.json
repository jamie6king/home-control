{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",

        "lib": [ "esnext" ],
        "target": "ESNext",
        "module": "CommonJS",
        "types": [ "node" ],

        "paths": {
            "@lib/*": [ "src/lib/*" ]
        }
    },

    "ts-node": {
        "esm": false,
        "transpileOnly": true,

        "require": [ "tsconfig-paths/register" ]
    }
}
