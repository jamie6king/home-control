{
    "include": ["src/**/*", "eslint.config.mjs"],

    "compilerOptions": {
        "rootDir": "./src",

        "lib": ["ESNext"],
        "target": "ESNext",
        "module": "CommonJS",
        "types": ["node"],

        "paths": {
            "@lib:*": ["./src/lib/*"],
        },
    },

    "ts-node": {
        "esm": false,
        "transpileOnly": true,

        "require": ["tsconfig-paths/register"],
    },
}
